# Copy to scripts/hms-real-installation-smoke.kerberos.env or pass with:
#   scripts/run-real-installation-smoke-kerberos.sh --env-file /path/to/file.env

HMS_SMOKE_AUTH=kerberos
HMS_SMOKE_URI=thrift://proxy-host:9083
HMS_SMOKE_SERVER_PRINCIPAL=hive/proxy-host.example.com@REALM.COM
HMS_SMOKE_CLIENT_PRINCIPAL=alice@REALM.COM
HMS_SMOKE_KEYTAB=/etc/security/keytabs/alice.keytab
HMS_SMOKE_KRB5_CONF=/etc/krb5.conf

# Optional Beeline / HiveServer2 SQL smoke from SMOKE.md. If unset, the SQL step is skipped in --scenario all.
# For Kerberos, the JDBC URL usually already includes principal=...
# HMS_SMOKE_BEELINE_JDBC_URL=jdbc:hive2://proxy-host:10000/default;principal=hive/proxy-host.example.com@REALM.COM
# HMS_SMOKE_BEELINE_BIN=beeline
# HMS_SMOKE_BEELINE_USER=alice
# HMS_SMOKE_BEELINE_KINIT=true
# HMS_SMOKE_HDP_CATALOG=hdp
# HMS_SMOKE_APACHE_CATALOG=apache
# HMS_SMOKE_HDP_READ_TABLE=some_table
# HMS_SMOKE_APACHE_READ_TABLE=some_table
# HMS_SMOKE_SQL_EXTERNAL_ROOT=/tmp/hms-proxy-smoke
# HMS_SMOKE_SQL_RUN_MATERIALIZED_VIEW=false
# HMS_SMOKE_HDP_RUN_TRANSACTIONAL_SQL=false
# HMS_SMOKE_APACHE_RUN_TRANSACTIONAL_SQL=false

# Optional fat jar override. By default the runner uses the newest target/hms-proxy-*-fat.jar.
# HMS_SMOKE_FAT_JAR=/opt/hms-proxy/hms-proxy-fat.jar

# Optional repeated HiveConf overrides separated by ';'
# HMS_SMOKE_EXTRA_CONF=hive.metastore.execute.setugi=false;hive.metastore.token.signature=proxy

HMS_SMOKE_USER=smoke-user
HMS_SMOKE_HOST=localhost
HMS_SMOKE_AGENT_INFO=hms-proxy-real-installation-smoke-kerberos

# Direct ACID / txn smoke
HMS_SMOKE_TXN_DB=hdp__default
HMS_SMOKE_TXN_TABLE=smoke_txn_tbl
HMS_SMOKE_TXN_LOCK=true

# Optional second txn target, for example to validate both default Apache and default Hortonworks catalogs.
# HMS_SMOKE_TXN_SECONDARY_DB=apache__default
# HMS_SMOKE_TXN_SECONDARY_TABLE=smoke_txn_tbl

# Non-default catalog synthetic lock smoke
HMS_SMOKE_LOCK_DB=apache__default
HMS_SMOKE_DB_LOCK_TYPE=SHARED_READ
HMS_SMOKE_DB_LOCK_LEVEL=DB
HMS_SMOKE_DB_LOCK_OPERATION_TYPE=NO_TXN
HMS_SMOKE_DB_LOCK_TRANSACTIONAL=false
HMS_SMOKE_LOCK_HEARTBEAT=true
HMS_SMOKE_LOCK_UNLOCK=true
HMS_SMOKE_LOCK_CLOSE_TXN=abort

# Optional partition rename/drop style lock smoke
HMS_SMOKE_LOCK_TABLE=smoke_managed_tbl
HMS_SMOKE_LOCK_PARTITION=p=2026-04-01
HMS_SMOKE_PARTITION_LOCK_TYPE=EXCLUSIVE
HMS_SMOKE_PARTITION_LOCK_LEVEL=PARTITION
HMS_SMOKE_PARTITION_LOCK_OPERATION_TYPE=NO_TXN
HMS_SMOKE_PARTITION_LOCK_TRANSACTIONAL=false

# Optional Hortonworks notification smoke. If left unset, the notification step is skipped in --scenario all.
# HMS_SMOKE_NOTIFICATION_DB=hdp__default
# HMS_SMOKE_NOTIFICATION_TABLE=smoke_txn_tbl
# HMS_SMOKE_NOTIFICATION_TXN_ID=1001
# HMS_SMOKE_NOTIFICATION_WRITE_ID=2001
# HMS_SMOKE_NOTIFICATION_FILES_ADDED=hdfs:///warehouse/tablespace/managed/hive/smoke_txn_tbl/delta_1001_1001_0000/bucket_00000
# HMS_SMOKE_NOTIFICATION_PARTITIONS=p=2026-04-01
# HMS_SMOKE_NOTIFICATION_NEGATIVE_DB=apache__default
# HMS_SMOKE_NOTIFICATION_NEGATIVE_TABLE=smoke_txn_tbl
# HMS_SMOKE_HDP_STANDALONE_METASTORE_JAR=/opt/hms-proxy/hive-metastore/hive-standalone-metastore-3.1.0.3.1.0.0-78.jar
